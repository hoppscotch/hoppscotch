        {"name": "Test Query", "url": "https://api.example.com/graphql", "headers": [], "variables": ""},
        {"name": "Another", "url": "https://test.com", "headers": [{"key": "Auth", "value": "token", "active": true}], "variables": "{\"limit\": 10}"}
      ]
    },
    {
