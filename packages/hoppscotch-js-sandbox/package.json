{
  "name": "@hoppscotch/js-sandbox",
  "version": "2.1.0",
  "description": "JavaScript sandboxes for running external scripts used by Hoppscotch clients",
  "type": "module",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./scripting": {
      "types": "./dist/scripting.d.ts",
      "import": "./dist/scripting.js",
      "require": "./dist/scripting.cjs"
    }
  },
  "types": "./index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lintfix": "eslint --fix .",
    "test": "vitest run",
    "build:lib-bundles": "rollup -c rollup.lib-bundles.config.js",
    "build": "pnpm run build:lib-bundles && vite build && tsc --emitDeclarationOnly",
    "clean": "pnpm tsc --build --clean",
    "postinstall": "pnpm run build",
    "prepublish": "pnpm run build",
    "do-lint": "pnpm run lint",
    "do-lintfix": "pnpm run lintfix",
    "do-typecheck": "pnpm exec tsc --noEmit",
    "do-build-prod": "pnpm run build",
    "do-test": "pnpm run test"
  },
  "keywords": [
    "hoppscotch",
    "sandbox",
    "js-sandbox",
    "apis",
    "test-runner"
  ],
  "author": "Hoppscotch (support@hoppscotch.io)",
  "license": "MIT",
  "dependencies": {
    "@hoppscotch/data": "workspace:^",
    "@types/lodash-es": "4.17.12",
    "acorn": "8.16.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chai": "6.2.2",
    "cheerio": "1.2.0",
    "crypto-js": "4.2.0",
    "faraday-cage": "0.1.0",
    "form-data": "4.0.4",
    "fp-ts": "2.16.11",
    "jsonpath-plus": "10.4.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "moment": "2.30.1",
    "node-forge": "1.4.0",
    "tv4": "1.3.0",
    "uuid": "13.0.0",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-unicode-property-regex": "7.28.6",
    "@digitak/esrun": "3.2.26",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.2",
    "@relmify/jest-fp-ts": "2.1.1",
    "@rollup/plugin-babel": "7.0.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@types/chai": "5.2.3",
    "@types/cheerio": "1.0.0",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "30.0.0",
    "@types/jsonpath-plus": "5.0.5",
    "@types/lodash": "4.17.24",
    "@types/moment": "2.13.0",
    "@types/node": "24.10.1",
    "@types/node-forge": "1.3.14",
    "@types/tv4": "1.2.33",
    "@types/uuid": "11.0.0",
    "@types/xml2js": "0.4.14",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "ajv6": "npm:ajv@6.12.6",
    "ajv6-formats": "npm:ajv-formats@1.6.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "io-ts": "2.2.22",
    "prettier": "3.8.3",
    "rollup": "4.60.4",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "isolated-vm": "6.1.2"
  },
  "peerDependenciesMeta": {
    "isolated-vm": {
      "optional": true
    }
  }
}
