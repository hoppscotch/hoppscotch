      "inputs": [
        null,
        {"name": "My Query", "url": "https://api.example.com/graphql"},
        {"v": 1, "name": "Test", "url": "https://test.com", "headers": [], "variables": ""},
        "invalid string"
      ]
    },
    {
      "id": "make-gql-request",
